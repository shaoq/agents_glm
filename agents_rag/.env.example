# LLM 平台 API 密钥（OpenAI 兼容端点；缺失则在需要时 fail-fast；真实 .env 不入库）
# 切换平台：改下方 LLM_BASE_URL + 模型名即可（智谱/DeepSeek/Moonshot/Qwen/本地 vLLM 等）
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Embedding
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIM=2048
EMBEDDING_MAX_BATCH=64
EMBEDDING_MAX_CONCURRENCY=8

# 视觉（图片描述生成）
VISION_MODEL=glm-4.5v

# 分块
CHUNK_SIZE=400
CHUNK_OVERLAP=64
PARENT_MAX_SIZE=1800

# 路径（相对 cwd；CLI 在 agents_rag/ 下运行）
DATA_DIR=./data
STORAGE_DIR=./storage
