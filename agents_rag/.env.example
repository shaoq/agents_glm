# 智谱 API 密钥（缺失则在需要时 fail-fast；真实 .env 不入库）
ZHIPUAI_API_KEY=

# Embedding
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIM=2048
EMBEDDING_MAX_BATCH=64
EMBEDDING_MAX_CONCURRENCY=8

# 视觉（图片描述生成）
VISION_MODEL=glm-4.5v

# 分块
CHUNK_SIZE=400
CHUNK_OVERLAP=64
PARENT_MAX_SIZE=1800

# 路径（相对 cwd；CLI 在 agents_rag/ 下运行）
DATA_DIR=./data
STORAGE_DIR=./storage
